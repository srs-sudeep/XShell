{
  "name": "GitHub Dark",
  "description": "GitHub.com dark mode — clean and minimal",
  "colors": {
    "background":  "#0d1117",
    "foreground":  "#c9d1d9",
    "prompt_user": "bright_cyan",
    "prompt_host": "bright_green",
    "prompt_cwd":  "bright_blue",
    "prompt_git":  "bright_magenta",
    "error":       "bright_red",
    "success":     "bright_green",
    "info":        "bright_blue",
    "warning":     "bright_yellow",
    "cursor":      "#58a6ff",
